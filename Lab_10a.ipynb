        "id": "90dd3441",
        "outputId": "1582fb77-8aa5-43e2-a823-ff4035faebea"
      },
      "source": [
        "def get_path(start, end, next_node):\n",
        "    if next_node[start][end] == None: # No path exists\n",
        "        return []\n",
        "\n",
        "    path = [start]\n",
        "    while start != end:\n",
        "        start = next_node[start][end]\n",
        "        path.append(start)\n",
        "    return path\n",
        "\n",
        "# Re-run Floyd-Warshall to get dist and next_node from the user_graph\n",
        "print(\"\\n--- Running Floyd-Warshall with path reconstruction on user input ---\")\n",
        "\n",
        "import copy\n",
        "# Using the previously input user_graph, make a deep copy to avoid modifying the original\n",
        "user_graph_for_path_copy = copy.deepcopy(user_graph)\n",
        "\n",
        "dist_path, next_node_path = floyd_warshall(user_graph_for_path_copy)\n",
        "\n",
        "print(\"\\nShortest distance matrix (for path finding):\")\n",
        "for row in dist_path:\n",
        "    print([val if val != float('inf') else 'inf' for val in row])\n",
        "\n",
        "# The next_node matrix shows the next vertex in the shortest path from i to j\n",
        "# print(\"\\nNext node matrix (for path finding):\")\n",
        "# for row in next_node_path:\n",
        "#     print(row)\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        start_node = int(input(\"Enter the start vertex (0-indexed): \"))\n",
        "        end_node = int(input(\"Enter the end vertex (0-indexed): \"))\n",
        "\n",
        "        if not (0 <= start_node < len(dist_path) and 0 <= end_node < len(dist_path)):\n",
        "            raise ValueError(\"Vertex index out of bounds.\")\n",
        "\n",
        "        path = []\n",
        "        # Check for negative cycle first if start and end are the same and distance is negative\n",
        "        if start_node == end_node and dist_path[start_node][end_node] < 0:\n",
        "             print(f\"A negative cycle exists involving node {start_node}, so the path is undefined.\")\n",
        "        else:\n",
        "            # Path reconstruction\n",
        "            temp_path = [start_node]\n",
        "            u = start_node\n",
        "            while u != end_node:\n",
        "                v = next_node_path[u][end_node]\n",
        "                if v == None: # No path exists\n",
        "                    break\n",
        "                temp_path.append(v)\n",
        "                u = v\n",
        "\n",
        "            if temp_path[-1] == end_node: # Path found\n",
        "                path = temp_path\n",
        "\n",
        "            if not path:\n",
        "                print(f\"No path found from {start_node} to {end_node}.\")\n",
        "            else:\n",
        "                total_distance = dist_path[start_node][end_node]\n",
        "                if total_distance == float('inf'):\n",
        "                    print(f\"No path found from {start_node} to {end_node}.\")\n",
        "                else:\n",
        "                    print(f\"Shortest path from {start_node} to {end_node}: {path}\")\n",
        "                    print(f\"Total distance: {total_distance}\")\n",
        "        break # Exit loop after valid input\n",
        "    except ValueError as e:\n",
        "        print(f\"Invalid input: {e}. Please enter valid integer vertex indices.\")"
      ],
