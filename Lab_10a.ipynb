      "source": [
        "import math\n",
        "\n",
        "def get_user_matrix():\n",
        "    while True:\n",
        "        try:\n",
        "            n = int(input(\"Enter the number of vertices (N): \"))\n",
        "            if n <= 0:\n",
        "                raise ValueError\n",
        "            break\n",
        "        except ValueError:\n",
        "            print(\"Invalid input. Please enter a positive integer for N.\")\n",
        "\n",
        "    print(f\"Enter the {n}x{n} matrix row by row. Use 'inf' for infinity and numbers for weights.\")\n",
        "    matrix = []\n",
        "    for i in range(n):\n",
        "        while True:\n",
        "            row_str = input(f\"Enter row {i+1} (space-separated values): \")\n",
        "            try:\n",
        "                row_values = []\n",
        "                for val_str in row_str.split():\n",
        "                    if val_str.lower() == 'inf':\n",
        "                        row_values.append(float('inf'))\n",
        "                    else:\n",
        "                        row_values.append(int(val_str))\n",
        "\n",
        "                if len(row_values) != n:\n",
        "                    raise ValueError(f\"Expected {n} values, but got {len(row_values)}.\")\n",
        "\n",
        "                matrix.append(row_values)\n",
        "                break\n",
        "            except ValueError as e:\n",
        "                print(f\"Invalid input for row {i+1}. Please enter {n} space-separated integers or 'inf'. Error: {e}\")\n",
